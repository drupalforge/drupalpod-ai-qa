[
  {
    "name": "CMS latest stable (empty DP_VERSION)",
    "description": "CMS template with no explicit version should resolve successfully",
    "env": {
      "DP_STARTER_TEMPLATE": "cms",
      "DP_VERSION": "",
      "DP_AI_MODULE": "ai"
    },
    "expect": {
      "should_succeed": true,
      "manifest_starter_template": "cms",
      "manifest_dp_version": "",
      "modules_resolved": ["ai"]
    }
  },
  {
    "name": "CMS 1.x",
    "description": "CMS 1.x template/version combination resolves successfully",
    "env": {
      "DP_STARTER_TEMPLATE": "cms",
      "DP_VERSION": "1.x",
      "DP_AI_MODULE": "ai"
    },
    "expect": {
      "should_succeed": true,
      "manifest_starter_template": "cms",
      "manifest_dp_version": "1.x",
      "project_package": "drupal/cms",
      "drupal_version_pattern": "^1\\.",
      "modules_resolved": ["ai"]
    }
  },
